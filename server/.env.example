# ── RAVA backend configuration ───────────────────────────────────────────────
# Copy this file to `.env` and adjust. Everything has a sane default for local
# development, so the server boots in demo mode even with no .env at all.

# Port the API listens on
PORT=3001

# development | production
NODE_ENV=development

# Public URL of the frontend (used for CORS + OAuth redirects back to the SPA)
APP_URL=http://localhost:5173

# Secret used to sign session JWTs. MUST be a long random string in production.
JWT_SECRET=dev-only-secret-change-me-in-production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Connection string for the database (tables are created automatically on boot).
# Quick local instance:
#   docker run -d --name rava-pg -e POSTGRES_PASSWORD=rava -e POSTGRES_USER=rava \
#     -e POSTGRES_DB=rava -p 5432:5432 postgres:16
DATABASE_URL=postgres://rava:rava@localhost:5432/rava

# ── Yandex OAuth ──────────────────────────────────────────────────────────────
# Register an application at https://oauth.yandex.ru/client/new
#   • Platform:           Web services
#   • Redirect URI:       http://localhost:5173/api/auth/yandex/callback
#   • Permissions/scopes: "Доступ к адресу электронной почты" (login:email)
#                         "Доступ к имени пользователя…"      (login:info)
# Then paste the issued ID / secret below.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Must match the Redirect URI registered in the Yandex app above.
# Routed through the frontend origin so the proxy hands it to this backend and
# the session cookie is stored on the app origin.
YANDEX_REDIRECT_URI=http://localhost:5173/api/auth/yandex/callback

# Real OAuth is the default (false). Set to "true" ONLY for local dev without
# credentials — it logs you in as a synthetic account. Never enable in prod.
YANDEX_DEMO=false

# ── Paid Telegram-community access ────────────────────────────────────────────
ACCESS_PRICE_RUB=990
ACCESS_DURATION_DAYS=30

# ── YooKassa / ЮKassa (https://yookassa.ru) ───────────────────────────────────
# Payment is intentionally MOCKED for now: with YOOKASSA_DEMO=true the "Оплатить"
# button settles instantly server-side (no money moves) and unlocks the real
# code → bot → group flow. To switch to real charges later, fill the keys below
# (Dashboard → "Настройки" → "API ключи"), set YOOKASSA_DEMO=false, and register
# the webhook (payment.succeeded) at  <public-url>/api/billing/webhook
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_DEMO=true

# ── Telegram bot (@BotFather) ─────────────────────────────────────────────────
# 1. /newbot in @BotFather → paste the token here.
# 2. Add the bot to your group/supergroup and make it ADMIN with rights to
#    "invite users via link" and "ban users".
# 3. Get the numeric group id (e.g. -1001234567890) and put it below.
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=
# Optional: deep-link username. If omitted it's read from getMe at startup.
TELEGRAM_BOT_USERNAME=
# Optional SOCKS proxy for all bot traffic (regions where Telegram is blocked).
# With the bundled Xray/VLESS sidecar: TELEGRAM_PROXY=socks5h://xray:1080
TELEGRAM_PROXY=
